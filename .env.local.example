# =============================================================================
# Vesti — Environment Variable Reference
# =============================================================================
# Copy this file to .env.local and fill in your vesti-dev credentials for
# local development. .env.local is gitignored and will never be committed.
#
# Production credentials (vesti-prod) are set in Vercel's environment variable
# dashboard — they are NEVER stored in any file in this repository.
#
# Two Supabase projects are required:
#   • vesti-dev  → used for .env.local (localhost)
#   • vesti-prod → used for Vercel environment variables (production)
# =============================================================================

# Project URL — found in Supabase: Settings → API → Project URL
# Example: https://abcdefghijklm.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon / public key — found in Supabase: Settings → API → Project API keys → anon public
# Safe to expose to the browser; access is governed by Row Level Security policies.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — found in Supabase: Settings → API → Project API keys → service_role
# ⚠️  Bypasses Row Level Security entirely.
# ⚠️  NEVER commit this value. NEVER reference it in client-side code.
# Used only by the server-side cron job handler (/api/cron).
SUPABASE_SERVICE_ROLE_KEY=

# Market data API key — Finnhub (https://finnhub.io/register)
# Free tier: 60 req/min, no daily cap.
FINNHUB_DATA_API_KEY=

# Cron endpoint secret — authenticates requests to /api/cron so only Vercel
# (or your local test runner) can trigger it.
# Generate with: openssl rand -hex 32
# Set the same value in Vercel: Project → Settings → Environment Variables
# The cron schedule itself is configured in vercel.json, not the Vercel dashboard.
CRON_SECRET=
